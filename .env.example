# Discord Bot Token (från Discord Developer Portal)
DISCORD_TOKEN=din_discord_bot_token_här

# Anthropic API Key (från console.anthropic.com)
ANTHROPIC_API_KEY=din_anthropic_api_key_här

# Workspace path (där era projekt finns)
WORKSPACE_PATH=/home/perssonisak1

# Claude Model (valfritt, default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Axona Brain vault (markdown second-brain — Gideons långtidsminne)
# Default: /workspace/axona-brain. På Hetzner: /home/axona/axona-brain.
BRAIN_PATH=/workspace/axona-brain

# Supabase (från supabase.com)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=din_supabase_anon_key_här

# OpenAI API Key (för embeddings, från platform.openai.com)
OPENAI_API_KEY=din_openai_api_key_här
